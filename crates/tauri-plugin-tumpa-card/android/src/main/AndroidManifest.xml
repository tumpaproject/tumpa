<?xml version="1.0" encoding="utf-8"?>
<!--
    NFC + USB host permissions for smartcard access. Features are marked
    required="false" so the app still installs on devices without the
    corresponding hardware — the plugin reports back "no transport
    available" at runtime instead.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.NFC" />

    <uses-feature
        android:name="android.hardware.nfc"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />

</manifest>
